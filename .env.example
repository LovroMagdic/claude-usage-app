# Copy this file to `.env` and fill in the values, then run the app.

CLAUDE_CLIENT_ID=

# API endpoints (only change if you know what you're doing).
CLAUDE_USAGE_URL=https://api.anthropic.com/api/oauth/usage
CLAUDE_TOKEN_URL=https://console.anthropic.com/v1/oauth/token
CLAUDE_OAUTH_BETA=oauth-2025-04-20

# Rate limiting for the /usage endpoint (seconds).
CLAUDE_MIN_LIMITS_INTERVAL=120
CLAUDE_BACKOFF_BASE=300
CLAUDE_BACKOFF_MAX=1800
